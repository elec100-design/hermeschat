# hermes-agent 컨테이너 환경변수 예시 — T-B01
# 실제 파일: server/.env  (gitignore에 포함됨 — 절대 커밋 금지)

# 사용자 식별자 (컨테이너 이름: hermes-user-{USER_ID})
USER_ID=dev

# hermes-agent 게이트웨이 Bearer 토큰 (앱 설정 > API Key와 동일)
HERMES_API_KEY=your-gateway-api-key-here

# Hermes Bridge Bearer 토큰 (앱 설정 > Bridge Token과 동일)
HERMES_BRIDGE_TOKEN=your-bridge-token-here

# LLM provider 키 (hermes-agent가 내부적으로 사용)
ANTHROPIC_API_KEY=sk-ant-...
OPENAI_API_KEY=sk-...

# 선택: 모델 표시 이름 (기본 "default")
MODEL_NAME=default

# 선택: 로컬 테스트용 포트 매핑 (기본 18642 / 18765)
LOCAL_GATEWAY_PORT=18642
LOCAL_BRIDGE_PORT=18765

# ── T-B03: cloud_gateway.py 설정 ─────────────────────────────────────────────

# Supabase 프로젝트 > Settings > API > JWT Secret
SUPABASE_JWT_SECRET=your-supabase-jwt-secret-here

# per-user API Key 파생 시드 — 64자 랜덤 문자열 권장
# 생성: python3 -c "import secrets; print(secrets.token_hex(32))"
GATEWAY_SECRET=your-gateway-secret-here

# cloud_gateway 리스닝 포트 (기본 8080)
CLOUD_GW_PORT=8080

# hermes-agent 컨테이너 이미지 이름 (docker build -t 로 빌드한 태그)
HERMES_IMAGE=hermes-agent:latest
